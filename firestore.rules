rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSystemAdminEmail() {
      return isSignedIn() && request.auth.token.email == 'aphiwatict@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (
        isSystemAdminEmail() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          getUserData().role == 'admin'
        )
      );
    }

    // User Profile Rules
    match /users/{userId} {
      // Users can read their own profile. Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      
      // On creation, the user must set their initial role to 'general' (unless they are the system admin email)
      allow create: if isOwner(userId) && (
        request.resource.data.role == 'general' ||
        (isSystemAdminEmail() && request.resource.data.role == 'admin')
      );
      
      // Users can update their own profile, but CANNOT change their role (unless they are admin). 
      // Admins have full access to change profiles and roles.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      
      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // Storyboard History Rules
    match /users/{userId}/storyboards/{storyboardId} {
      // Users have full control over their own storyboard history logs. Admins can read them.
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // Daily Credit Usage Rules (Increment-Only Protection)
    match /users/{userId}/usage/{date} {
      // Users and admins can read usage stats
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create a daily usage log, but the initial count must be exactly 1
      allow create: if isOwner(userId) && request.resource.data.count == 1;
      
      // Users can only increment their daily counter by exactly 1. 
      // This prevents users from resetting, decreasing, or forging their usage credits.
      allow update: if isOwner(userId) && 
        request.resource.data.count == resource.data.count + 1;
        
      // Usage logs can never be deleted by normal users
      allow delete: if isAdmin();
    }
  }
}
